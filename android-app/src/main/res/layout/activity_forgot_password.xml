<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Recuperar Contraseña"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2563EB"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"/>

    <LinearLayout
        android:id="@+id/layoutStepEmail"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Introduce tu correo electrónico para obtener tus preguntas de seguridad."
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/etForgotEmail"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Correo electrónico"
            android:inputType="textEmailAddress"
            android:background="@drawable/edittext_border"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <Button
            android:id="@+id/btnGetQuestions"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Continuar"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/backToLoginText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_gravity="center"
            android:text="¿Ya recordaste tu clave? Inicia sesión"
            android:textColor="#1A73E8"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutStepQuestions"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/tvQuestion1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pregunta 1"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etAnswer1"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Tu respuesta"
            android:background="@drawable/edittext_border"
            android:padding="12dp"
            android:layout_marginBottom="20dp"/>

        <TextView
            android:id="@+id/tvQuestion2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Pregunta 2"
            android:textStyle="bold"
            android:layout_marginBottom="8dp"/>

        <EditText
            android:id="@+id/etAnswer2"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:hint="Tu respuesta"
            android:background="@drawable/edittext_border"
            android:padding="12dp"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btnVerifyAnswers"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="Verificar Identidad"
            android:backgroundTint="#2563EB"
            android:textColor="@android:color/white"/>

        <TextView
            android:id="@+id/backToLoginTextVerify"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:layout_gravity="center"
            android:text="¿Ya recordaste tu clave? Inicia sesión"
            android:textColor="#1A73E8"
            android:textSize="14sp"
            android:fontFamily="sans-serif-medium"
            android:clickable="true"
            android:focusable="true"/>

        <ProgressBar
            android:id="@+id/forgotProgress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>