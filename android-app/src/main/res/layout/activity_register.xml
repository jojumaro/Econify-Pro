<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F7FA"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:padding="24dp"
        android:orientation="vertical">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="16dp"
            app:cardElevation="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Econify Pro"
                    android:layout_gravity="center"
                    android:textColor="#1A73E8"
                    android:textSize="26sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gestión inteligente de tus finanzas"
                    android:layout_gravity="center"
                    android:textColor="#5F6368"
                    android:textSize="14sp"
                    android:layout_marginBottom="24dp"/>

                <EditText
                    android:id="@+id/nameInput"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Nombre"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <EditText
                    android:id="@+id/lastnameInput"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Apellidos"
                    android:inputType="textPersonName"
                    android:layout_marginBottom="12dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <EditText
                    android:id="@+id/emailInput"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Correo electrónico"
                    android:inputType="textEmailAddress"
                    android:layout_marginBottom="12dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <EditText
                    android:id="@+id/passwordInput"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Contraseña"
                    android:inputType="textPassword"
                    android:layout_marginBottom="12dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <EditText
                    android:id="@+id/confirmPasswordInput"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Confirmar contraseña"
                    android:inputType="textPassword"
                    android:layout_marginBottom="20dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguridad de la cuenta"
                    android:textColor="#1A73E8"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"/>

                <Spinner
                    android:id="@+id/question1Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/edit_text_rounded"
                    android:paddingLeft="10dp"/>

                <EditText
                    android:id="@+id/answer1Input"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Respuesta a pregunta 1"
                    android:inputType="text"
                    android:layout_marginBottom="16dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <Spinner
                    android:id="@+id/question2Spinner"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:layout_marginBottom="8dp"
                    android:background="@drawable/edit_text_rounded"
                    android:paddingLeft="10dp"/>

                <EditText
                    android:id="@+id/answer2Input"
                    android:layout_width="match_parent"
                    android:layout_height="55dp"
                    android:hint="Respuesta a pregunta 2"
                    android:inputType="text"
                    android:layout_marginBottom="24dp"
                    android:paddingLeft="15dp"
                    android:background="@drawable/edit_text_rounded"/>

                <ProgressBar
                    android:id="@+id/loginProgress"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:layout_marginBottom="12dp"
                    android:visibility="gone" />

                <Button
                    android:id="@+id/registerButton"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:text="REGISTRAR"
                    android:textStyle="bold"
                    android:backgroundTint="#1A73E8"
                    android:textColor="@android:color/white"
                    app:cornerRadius="8dp"/>

                <TextView
                    android:id="@+id/goToLogin"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="¿Ya eres miembro? Inicia sesión"
                    android:gravity="center"
                    android:layout_marginTop="20dp"
                    android:textColor="#1A73E8"
                    android:textStyle="bold" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>